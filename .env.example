# Synapse AI - Environment Variables Example

# --- Backend (FastAPI) ---
OPENAI_API_KEY=your_openai_api_key_here
BACKEND_PORT=8000
LOG_LEVEL=INFO

# --- n8n Orchestration ---
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/synapse-ai

# --- Frontend (Optional/Global) ---
API_BASE_URL=http://localhost:8000
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/synapse-ai
